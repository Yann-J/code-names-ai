# OpenAI (default)
LLM_API=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_KEY=sk-...

# Mistral
# LLM_API=https://api.mistral.ai/v1
# LLM_MODEL=mistral-small
# LLM_KEY=...

# Ollama (local, no real key needed)
# LLM_API=http://localhost:11434/v1
# LLM_MODEL=llama3.2
# LLM_KEY=ollama

# Optional overrides
# CODENAMES_AI_FASTTEXT_PATH=/path/to/cc.en.300.bin
# CODENAMES_AI_CACHE_DIR=/path/to/cache
